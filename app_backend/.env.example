# =============================================================================
# BACKEND (FastAPI) — copie para "app_backend/.env"
#
# Comando na raiz do repo:  copy app_backend\.env.example app_backend\.env
#
# Variáveis NEXT_PUBLIC_* do Next ficam na RAIZ (.env.local), não aqui.
# =============================================================================

# --- App
APP_NAME=Welligton API
# true = CORS permissivo em dev; em produção use false e CORS_ORIGINS explícitos.
DEBUG=true

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4200,http://127.0.0.1:4200

# -----------------------------------------------------------------------------
# PostgreSQL — rode: docker compose up -d db   (na raiz do repo)
# Host 127.0.0.1 porta 5433 (evita conflito com Postgres local na 5432).
# Credenciais padrão do compose: app / app / appdb
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://app:app@127.0.0.1:5433/appdb

# JWT — gere uma string longa e aleatória em produção
SECRET_KEY=dev-secret-change-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# RabbitMQ — docker compose up -d rabbitmq
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://app:app@127.0.0.1:5672/%2f

# -----------------------------------------------------------------------------
# MongoDB (auditoria) — docker compose up -d mongo
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://app:app@127.0.0.1:27017
MONGO_AUDIT_DB=auditdb
MONGO_AUDIT_COLLECTION=product_events
MONGO_BUSINESS_AUDIT_COLLECTION=business_events

# -----------------------------------------------------------------------------
# Mercado Pago (preferências no servidor)
# Painel → Credenciais de teste → Access Token (não é a Public Key do Next)
# -----------------------------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=cole_seu_access_token_de_teste_aqui

# Mesma origem que você abre no navegador no Next (retorno após pagamento).
# http://localhost → preferência SEM auto_return (evita erro 400 do MP). https://... → com auto_return.
FRONTEND_URL=http://localhost:3000

# Notificações IPN/webhook: URL pública HTTPS onde o MP envia avisos (não funciona com localhost).
# Opção A — FastAPI: https://SEU_DOMINIO/mercado-pago/notifications
# Opção B — Lambda (API Gateway): código em infra/aws-lambda/mercadopago-webhook/lambda_function.py
# Em dev: ngrok http 8000 → MERCADO_PAGO_NOTIFICATION_URL=https://xxxx.ngrok-free.app/mercado-pago/notifications
# MERCADO_PAGO_NOTIFICATION_URL=

# Lambda (ou outro worker) chama POST /internal/mercadopago/confirm-payment com este segredo no header
# X-Internal-Webhook-Secret — gere uma string longa aleatória e replique na variável da função Lambda.
# MERCADO_PAGO_INTERNAL_WEBHOOK_SECRET=

# Na AWS Lambda (mercadopago-webhook), aponte para a URL pública do backend, ex.:
# MERCADO_PAGO_CONFIRM_PAYMENT_URL=https://api.seudominio.com/internal/mercadopago/confirm-payment
