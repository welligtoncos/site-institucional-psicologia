# =============================================================================
# FRONTEND (Next.js) — copie este arquivo para ".env.local" na RAIZ do repositório
# (mesma pasta que package.json). Comando: copy .env.example .env.local  (PowerShell)
#
# O Next.js NÃO lê app_backend/.env. Variáveis NEXT_PUBLIC_* ficam sempre aqui.
# =============================================================================

# --- Backend API (SSR e browser)
# URL que o servidor Next usa ao chamar a API (scripts, route handlers).
BACKEND_API_URL=http://127.0.0.1:8000
# URL que o navegador usa (portal, Mercado Pago fetch). Mesmo host/porta da API em dev.
NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8000

# --- Mercado Pago (Wallet / Checkout Pro)
# Painel: https://www.mercadopago.com.br/developers/panel/app → Credenciais de teste → Public Key
# Sem espaço antes/depois do "=". Reinicie "npm run dev" após alterar.
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=cole_sua_public_key_de_teste_aqui

# --- E-mail (formulário de contato — opcional em dev)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Clinica Harmonia <onboarding@resend.dev>
CLINIC_CONTACT_EMAIL=contato@clinicaharmonia.com.br

# --- Painel admin (disponibilidade — opcional)
ADMIN_API_TOKEN=dev-admin-token-troque-em-producao

# --- Agenda / portal
AVAILABILITY_DAYS_AHEAD=21
